	<file path="catalog/controller/extension/feed/custom.php" error="log">
		<operation error="skip">
			<search trim="false"><![CDATA[                                //categories]]></search>
			<add position="replace" offset="5" trim="false"><![CDATA[                                //categories
                                $product_categories = $this->merchant->getCategories($product_id);
                                if (empty($product_categories)) {
                                    continue;
                                }
                                $category_path_ids = [];]]></add>
		</operation>
	</file>
</modification>
